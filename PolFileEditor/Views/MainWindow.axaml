<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PolFileEditor.ViewModels"
        xmlns:controls="using:PolFileEditor.Controls"
        x:Class="PolFileEditor.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1080" Height="720"
        MinWidth="640" MinHeight="400"
        Title="{Binding WindowTitle}">

    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+N" Command="{Binding NewCommand}" />
        <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenCommand}" />
        <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveCommand}" />
        <KeyBinding Gesture="Ctrl+Shift+S" Command="{Binding SaveAsCommand}" />
    </Window.KeyBindings>

    <Window.DataTemplates>

        <!-- A single validated field: label, colored input, and explanation. -->
        <DataTemplate DataType="vm:ValidatedField">
            <StackPanel Width="150" Margin="4,2" Spacing="2">
                <SelectableTextBlock Text="{Binding Label}" FontSize="11" Opacity="0.75" />
                <Border BorderBrush="{Binding Severity, Converter={StaticResource SeverityToBrush}}"
                        BorderThickness="2" CornerRadius="5">
                    <TextBox Text="{Binding Value, Mode=TwoWay}"
                             ToolTip.Tip="{Binding Message}" />
                </Border>
                <SelectableTextBlock Text="{Binding Message}"
                           IsVisible="{Binding HasMessage}"
                           Foreground="{Binding Severity, Converter={StaticResource SeverityToBrush}}"
                           TextWrapping="Wrap" FontSize="11" MaxWidth="150" />
            </StackPanel>
        </DataTemplate>

        <!-- One named-network alias row. -->
        <DataTemplate DataType="vm:NamedNetworkViewModel">
            <Grid ColumnDefinitions="200,Auto,Auto" Margin="0,2">
                <StackPanel Grid.Column="0" Margin="4,2" Spacing="2">
                    <SelectableTextBlock Text="Name" FontSize="11" Opacity="0.75" />
                    <TextBox Text="{Binding Name, Mode=TwoWay}"
                             PlaceholderText="e.g. China" />
                </StackPanel>
                <ContentControl Grid.Column="1" Content="{Binding Cidr}" />
                <Button Grid.Column="2" VerticalAlignment="Top" Margin="4,18,0,0"
                        Command="{Binding RemoveSelfCommand}" ToolTip.Tip="Delete network">
                    <PathIcon Data="{StaticResource TrashIcon}" Width="16" Height="16" />
                </Button>
            </Grid>
        </DataTemplate>

        <!-- One firewall rule. -->
        <DataTemplate DataType="vm:RuleViewModel">
            <!-- Outer border paints the theme's default window background so a task's
                 color tint can't bleed through; the inner border adds the specificity
                 tint on top of it. -->
            <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="1" CornerRadius="6" Margin="0,4"
                    Background="{Binding $parent[Window].Background}">
                <Border CornerRadius="6" Padding="10">
                    <Border.Background>
                        <MultiBinding Converter="{StaticResource SpecificityFill}">
                            <Binding Path="Action" />
                            <Binding Path="Specificity" />
                        </MultiBinding>
                    </Border.Background>
                <StackPanel Spacing="6">
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                        <SelectableTextBlock Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0"
                                   FontWeight="Bold"
                                   Text="{Binding RuleNumber, StringFormat='{}{0}:'}" />
                        <TextBox Grid.Column="1" VerticalAlignment="Center"
                                 Text="{Binding Comment, Mode=TwoWay}"
                                 PlaceholderText="Comment / note" />
                        <Button Grid.Column="2" Margin="0,0,4,0" Command="{Binding DuplicateSelfCommand}"
                                ToolTip.Tip="Duplicate rule">
                            <PathIcon Data="{StaticResource CopyIcon}" Width="16" Height="16" />
                        </Button>
                        <Button Grid.Column="3" Command="{Binding RemoveSelfCommand}"
                                ToolTip.Tip="Delete rule">
                            <PathIcon Data="{StaticResource TrashIcon}" Width="16" Height="16" />
                        </Button>
                    </Grid>

                    <WrapPanel Orientation="Horizontal">
                        <StackPanel Width="150" Margin="4,2" Spacing="2">
                            <SelectableTextBlock Text="Action" FontSize="11" Opacity="0.75" />
                            <ComboBox HorizontalAlignment="Stretch"
                                      ItemsSource="{Binding ActionOptions}"
                                      SelectedItem="{Binding Action, Mode=TwoWay}" />
                        </StackPanel>
                        <ContentControl Content="{Binding MacSource}" />
                        <ContentControl Content="{Binding MacDest}" />
                        <ContentControl Content="{Binding IpSource}" />
                        <ContentControl Content="{Binding IpDest}" />
                        <StackPanel Width="150" Margin="4,2" Spacing="2">
                            <SelectableTextBlock Text="IP Protocol" FontSize="11" Opacity="0.75" />
                            <controls:ProtocolPicker SelectedProtocol="{Binding SelectedProtocol, Mode=TwoWay}" />
                        </StackPanel>
                        <ContentControl Content="{Binding PortSource}" />
                        <ContentControl Content="{Binding PortDest}" />
                    </WrapPanel>

                    <SelectableTextBlock Text="{Binding Summary}"
                               FontStyle="Italic" Opacity="0.75"
                               TextWrapping="Wrap" FontSize="12" Margin="4,0" />

                    <Border HorizontalAlignment="Left" Margin="4,0"
                            Background="#20808080" CornerRadius="10" Padding="8,2"
                            ToolTip.Tip="Specificity: number of match fields this rule constrains. More specific rules have higher implicit priority; Allow overrides Block.">
                        <SelectableTextBlock Text="{Binding SpecificityText}" FontSize="11" FontWeight="SemiBold" />
                    </Border>

                    <!-- Collision annotations: this rule wins (green) / is overridden (red). -->
                    <Border IsVisible="{Binding HasOverrides}"
                            Background="#2246A758" CornerRadius="4" Padding="8,4">
                        <SelectableTextBlock Text="{Binding OverridesText}"
                                   Foreground="#46A758" FontWeight="SemiBold"
                                   TextWrapping="Wrap" FontSize="12" />
                    </Border>

                    <Border IsVisible="{Binding HasOverridden}"
                            Background="#22E5484D" CornerRadius="4" Padding="8,4">
                        <SelectableTextBlock Text="{Binding OverriddenText}"
                                   Foreground="#E5484D" FontWeight="SemiBold"
                                   TextWrapping="Wrap" FontSize="12" />
                    </Border>

                    <Border IsVisible="{Binding HasRuleWarning}"
                            Background="#22B88600" CornerRadius="4" Padding="8,4">
                        <SelectableTextBlock Text="{Binding RuleWarning}"
                                   Foreground="{Binding WorstSeverity, Converter={StaticResource SeverityToBrush}}"
                                   TextWrapping="Wrap" FontSize="12" />
                    </Border>
                </StackPanel>
                </Border>
            </Border>
        </DataTemplate>

        <!-- One task group. -->
        <DataTemplate DataType="vm:TaskViewModel">
            <Border BorderBrush="{Binding Number, Converter={StaticResource TaskColor}}"
                    Background="{Binding Number, Converter={StaticResource TaskColor}, ConverterParameter=fill}"
                    BorderThickness="2" CornerRadius="8" Margin="0,6" Padding="12">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <SelectableTextBlock Grid.Column="0" VerticalAlignment="Center"
                                   FontWeight="Bold" FontSize="16"
                                   Foreground="{Binding Number, Converter={StaticResource TaskColor}}"
                                   Text="{Binding Title}" />
                        <Button Grid.Column="1" Command="{Binding RemoveSelfCommand}"
                                ToolTip.Tip="Delete task">
                            <PathIcon Data="{StaticResource TrashIcon}" Width="16" Height="16" />
                        </Button>
                    </Grid>
                    <ItemsControl ItemsSource="{Binding Rules}" />
                    <Button Content="+" FontSize="18" Padding="12,2"
                            Command="{Binding AddRuleCommand}"
                            HorizontalAlignment="Left" ToolTip.Tip="Add rule" />
                </StackPanel>
            </Border>
        </DataTemplate>

    </Window.DataTemplates>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New" Command="{Binding NewCommand}" InputGesture="Ctrl+N" />
                <MenuItem Header="_Open..." Command="{Binding OpenCommand}" InputGesture="Ctrl+O" />
                <Separator />
                <MenuItem Header="_Save" Command="{Binding SaveCommand}" InputGesture="Ctrl+S" />
                <MenuItem Header="Save _As..." Command="{Binding SaveAsCommand}" InputGesture="Ctrl+Shift+S" />
                <Separator />
                <MenuItem Header="E_xit" Command="{Binding ExitCommand}" />
            </MenuItem>
        </Menu>

        <Border DockPanel.Dock="Bottom" Padding="12,6"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <SelectableTextBlock Grid.Column="0" VerticalAlignment="Center"
                           Text="{Binding StatusMessage}" Opacity="0.8" />
                <SelectableTextBlock Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0"
                           Text="{Binding ErrorCount, StringFormat='Errors: {0}'}" />
                <SelectableTextBlock Grid.Column="2" VerticalAlignment="Center"
                           Text="{Binding WarningCount, StringFormat='Warnings: {0}'}" />
            </Grid>
        </Border>

        <ScrollViewer>
            <StackPanel Margin="14" Spacing="10">
                <Expander Header="File header comments (the '#' markers are added automatically)">
                    <TextBox Text="{Binding HeaderText, Mode=TwoWay}"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             MinHeight="140" />
                </Expander>
                <Expander Header="Known networks (name your subnets for readable rule descriptions)">
                    <StackPanel Spacing="4">
                        <ItemsControl ItemsSource="{Binding KnownNetworks}" />
                        <Button Content="+" FontSize="18" Padding="12,2"
                                Command="{Binding AddNetworkCommand}"
                                HorizontalAlignment="Left" Margin="0,4,0,0"
                                ToolTip.Tip="Add network" />
                    </StackPanel>
                </Expander>
                <ItemsControl ItemsSource="{Binding Tasks}" />
                <Button Content="+" FontSize="18" Padding="12,2"
                        Command="{Binding AddTaskCommand}"
                        HorizontalAlignment="Left" Margin="0,4,0,0" ToolTip.Tip="Add task" />
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
