<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="PolFileEditor.Views.ConfirmDialog"
        Width="440" SizeToContent="Height" CanResize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Title="Pol File Editor">
    <StackPanel Margin="24" Spacing="16">
        <SelectableTextBlock x:Name="TitleText" FontWeight="SemiBold" FontSize="15" TextWrapping="Wrap" />
        <SelectableTextBlock x:Name="MessageText" TextWrapping="Wrap" />
        <StackPanel x:Name="ButtonsPanel" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" />
    </StackPanel>
</Window>
